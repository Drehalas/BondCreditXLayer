# X Layer testnet JSON-RPC endpoint
XLAYER_TESTNET_RPC_URL=https://testrpc.xlayer.tech

# PostgreSQL URL for Prisma (example)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bondcredit?schema=public

# Hex private key for deployer (0x...)
DEPLOYER_PRIVATE_KEY=

# Latest xlayer testnet deployments
BONDCREDIT_SUBSCRIPTION_MANAGER=0xAEA215B9F67E0d87B9B89828A1F2dE365Ef1EAd5
BONDCREDIT_PAYMENT_GUARANTOR=0x137bee465E12A5F82e051ec2185F2477a32c4f70

# Enable trade execution only after agentic wallet identity is registered in DB.
# Optional: set to "simulated" for deterministic testnet/demo execution path.
BONDCREDIT_TRADE_EXECUTOR_MODE=simulated

# Real Uniswap V2 mode (set BONDCREDIT_TRADE_EXECUTOR_MODE=uniswap-v2)
# BONDCREDIT_UNISWAP_V2_ROUTER=0x...

# Trade token catalog is now loaded from:
# server/data/uniswap-token-list.json
# Filter which token slice to expose from static list:
# BONDCREDIT_TOKEN_LIST_SCOPE=mainnet  # or testnet
# Optional chainId overrides for parser:
# BONDCREDIT_TOKEN_LIST_MAINNET_CHAIN_ID=1
# BONDCREDIT_TOKEN_LIST_TESTNET_CHAIN_ID=1952
