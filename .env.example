# X Layer testnet JSON-RPC endpoint
XLAYER_TESTNET_RPC_URL=https://testrpc.xlayer.tech

# X Layer mainnet JSON-RPC endpoint
XLAYER_MAINNET_RPC_URL=https://rpc.xlayer.tech

# Backend network selector
BONDCREDIT_NETWORK=xlayer-mainnet

# PostgreSQL URL for Prisma (example)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bondcredit?schema=public

# Hex private key for deployer (0x...)
DEPLOYER_PRIVATE_KEY=

# Latest xlayer testnet deployments
BONDCREDIT_SUBSCRIPTION_MANAGER=0xAEA215B9F67E0d87B9B89828A1F2dE365Ef1EAd5
BONDCREDIT_PAYMENT_GUARANTOR=0x137bee465E12A5F82e051ec2185F2477a32c4f70

# Mainnet deployments (fill after deploying)
BONDCREDIT_MAINNET_SUBSCRIPTION_MANAGER=0xCEa6DF320e3233e17e3f66949F51D0ef10ad4a08
BONDCREDIT_MAINNET_PAYMENT_GUARANTOR=0xD10f3D2790EAED337DB04690D9F02B4Be04400da

# Legacy generic keys still supported by backend for compatibility
# BONDCREDIT_SUBSCRIPTION_MANAGER=
# BONDCREDIT_PAYMENT_GUARANTOR=

# Frontend runtime mainnet addresses
# VITE_BONDCREDIT_SUBSCRIPTION_MANAGER=0xCEa6DF320e3233e17e3f66949F51D0ef10ad4a08
# VITE_BONDCREDIT_PAYMENT_GUARANTOR=0xD10f3D2790EAED337DB04690D9F02B4Be04400da
# VITE_BONDCREDIT_CHAIN_ID=196

# Enable trade execution only after agentic wallet identity is registered in DB.
# Optional: set to "simulated" for deterministic testnet/demo execution path.
BONDCREDIT_TRADE_EXECUTOR_MODE=simulated

# Real Uniswap V2 mode (set BONDCREDIT_TRADE_EXECUTOR_MODE=uniswap-v2)
# BONDCREDIT_UNISWAP_V2_ROUTER=0x...

# Trade token catalog is now loaded from:
# server/data/uniswap-token-list.json
# Optional OKX DEX base URL override (use web3 endpoint if www is blocked):
# BONDCREDIT_OKX_DEX_BASE_URL=https://web3.okx.com
# OKX API key and secret for signed request authentication
# Required for production use of OKX DEX endpoints:
# BONDCREDIT_OKX_API_KEY=your_okx_api_key
# BONDCREDIT_OKX_SECRET_KEY=your_okx_secret_key
# BONDCREDIT_OKX_API_PASSPHRASE=your_okx_passphrase (if required)
# BONDCREDIT_OKX_PROJECT_ID=your_okx_project_id (required for some Web3 keys)
# BONDCREDIT_OKX_AUTH_DEBUG=1 (prints TIMESTAMP, REQUEST PATH, PREHASH, SIGNATURE, runs signer self-check)
# Filter which token slice to expose from static list:
# BONDCREDIT_TOKEN_LIST_SCOPE=mainnet  # or testnet
# Optional chainId overrides for parser:
# BONDCREDIT_TOKEN_LIST_MAINNET_CHAIN_ID=196
# BONDCREDIT_TOKEN_LIST_TESTNET_CHAIN_ID=1952
# Optional global fallback chainId used by quote/swap + token list parser:
# BONDCREDIT_CHAIN_ID=196
